{
  "name": "hanibi-app",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "validate": "npm run typecheck && npm run lint",
    "prebuild:android": "npm run validate",
    "prebuild:ios": "npm run validate",
    "clean": "react-native clean",
    "clean:android": "cd android && ./gradlew clean && cd ..",
    "clean:ios": "cd ios && xcodebuild clean && cd .."
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.26",
    "@tanstack/react-query": "^5.90.2",
    "axios": "^1.12.2",
    "react": "19.0.0",
    "react-native": "0.79.5",
    "react-native-config": "^1.5.9",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-vector-icons": "^10.2.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.2",
    "@babel/runtime": "^7.25.2",
    "@react-native/babel-preset": "^0.79.5",
    "@react-native/eslint-config": "^0.79.5",
    "@react-native/metro-config": "^0.79.5",
    "@react-native/typescript-config": "^0.79.5",
    "@types/react": "~19.0.10",
    "@types/react-native": "^0.79.5",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "jest": "^29.2.1",
    "metro-react-native-babel-preset": "^0.79.5",
    "typescript": "~5.8.3"
  },
  "private": true
}
