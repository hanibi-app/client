{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "App.tsx",
    "index.js",
    "**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "android",
    "ios",
    "dist",
    "build",
    "**/*.config.js",
    "babel.config.js",
    "metro.config.js"
  ]
}